{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trace-to-eval.dev/schemas/v1/run-report.schema.json",
  "title": "Trace To Eval Run Report",
  "type": "object",
  "required": ["run_id", "generated_at", "summary", "case_results"],
  "additionalProperties": false,
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "minLength": 1 },
    "summary": {
      "type": "object",
      "required": ["passed", "failed", "skipped"],
      "additionalProperties": false,
      "properties": {
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "skipped": { "type": "integer", "minimum": 0 }
      }
    },
    "case_results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["case_id", "suite", "trace_id", "status", "check_results"],
        "additionalProperties": false,
        "properties": {
          "case_id": { "type": "string" },
          "suite": { "type": "string" },
          "trace_id": { "type": "string" },
          "status": { "type": "string", "enum": ["passed", "failed", "skipped"] },
          "check_results": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type", "status", "message"],
              "additionalProperties": false,
              "properties": {
                "type": { "type": "string" },
                "status": { "type": "string", "enum": ["passed", "failed", "skipped"] },
                "message": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}

