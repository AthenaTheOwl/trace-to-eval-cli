{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trace-to-eval.dev/schemas/v1/eval-case.schema.json",
  "title": "Trace To Eval Case Set",
  "type": "object",
  "required": ["cases"],
  "additionalProperties": false,
  "properties": {
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "suite", "trace_id", "trace_file", "checks"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "suite": { "type": "string", "minLength": 1 },
          "trace_id": { "type": "string", "minLength": 1 },
          "trace_file": { "type": "string", "minLength": 1 },
          "checks": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["type"],
              "additionalProperties": false,
              "properties": {
                "type": {
                  "type": "string",
                  "enum": [
                    "text_present",
                    "text_absent",
                    "citation_span_present",
                    "tool_call_allowed",
                    "refusal_required"
                  ]
                },
                "value": {
                  "oneOf": [
                    { "type": "string" },
                    { "type": "boolean" }
                  ]
                },
                "pattern": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}

